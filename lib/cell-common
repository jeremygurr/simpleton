#!/bin/bash

SIMPLETON_EXTENSIONS=${SIMPLETON_EXTENSIONS:-$SIMPLETON_REPO/..}

# don't let other users read any files written by these scripts
umask 0077

get_current_cube() {
local subject=$1
current_cube=
while [[ ${#subject} > 1 && $subject =~ / ]]; do
  if [[ -f "$subject/cube-context" ]]; then
    current_cube=$subject
    break
  fi
  subject=${subject%/*}
done
[[ "$current_cube" ]]
}

get_tmp_path() {
local current_cube=$1
if [[ -d $current_cube/tmp ]]; then
  tmp_path=$current_cube/tmp
elif [[ -d ~/tmp ]]; then
  tmp_path=~/tmp
else
  tmp_path=/tmp
fi
return 0
}

decrypt_file() {

local from=$1; shift
local to=$1; shift
local tmp_path=$tmp_path
local current_cube=$current_cube
local user_private_key=${user_private_key:-~/.ssh/id_rsa}

trace 0 "Decrypting $from to $to"
begin_function

  if [[ ! -d "$tmp_path" ]]; then
    err "tmp_path must be set to a directory before calling decrypt_file."
    fail
  fi

  if [[ ! -d "$current_cube" ]]; then
    err "current_cube must be set before calling decrypt_file"
    fail
  fi

  if [[ ! -f "$current_cube/key/key.$USER" ]]; then
    err "You don't have a key for this cube ($USER). Ask someone who does to add you. Existing keys:" 
    find $current_cube/key -name "key.*" >&2
    fail
  fi

  # extract the main key
  if ! openssl pkeyutl -decrypt -inkey $user_private_key -in "$current_cube/key/key.$USER" -out $tmp_path/main; then
    err "Failed to decrypt main key." 
    fail
  fi

  # decrypt the secret file
  if ! openssl enc -aes256 -in $from -out $to -d -pass file:$tmp_path/main; then 
    err "Failed to decrypt secret file." 
    fail
  fi

end_function
handle_return

}

encrypt_file() {

local from=$1; shift
local to=$1; shift
local tmp_path=$tmp_path
local current_cube=$current_cube
local user_private_key=${user_private_key:-~/.ssh/id_rsa}

trace 0 "Encrypting $from to $to"
begin_function

  if [[ ! -d "$tmp_path" ]]; then
    err "tmp_path must be set to a directory before calling decrypt_file."
    fail
  fi

  if [[ ! -d "$current_cube" ]]; then
    err "current_cube must be set before calling decrypt_file"
    fail
  fi

  if [[ ! -f "$current_cube/key/key.$USER" ]]; then

    local key_count=$(find $current_cube/key -mindepth 1 -maxdepth 1 -name 'key.*' -type f | wc -l)

    if [[ $key_count > 0 ]]; then

      err "You don't have a key for this cube ($USER). Ask someone who does to add you. Existing keys:" 
      find $current_cube/key -name "key.*" >&2
      fail

    else

      trace 0 "There are no keys for this cube yet. Will create a new key."

      # create a new main key
      if ! openssl rand -base64 40 >$tmp_path/main; then
        err "Failed to generate new main key."
        fail
      fi

      # create a compatible public key from the user's private key
      if ! openssl pkey -in $user_private_key -out $tmp_path/public -pubout; then 
        err "Failed to convert private key to public key."
        fail
      fi

      # encrypt main key with given user key
      if ! openssl pkeyutl -encrypt -pubin -inkey $tmp_path/public -in $tmp_path/main -out $current_cube/key/key.$USER; then
        err "Failed to encrypt main key."
        fail
      fi

    fi
  else 
    # extract the main key
    if ! openssl pkeyutl -decrypt -inkey $user_private_key -in $current_cube/key/key.$USER -out $tmp_path/main; then
      err "Failed to decrypt main key." 
      fail
    fi
  fi
    
  # encrypt the file with main key
  if ! openssl enc -aes256 -in $from -out $to -pass file:$tmp_path/main; then
    err "Failed to create new secret file."
    fail
  fi

end_function
handle_return

}

# produces: cell_id, dim_string
get_cell_id() {

local dim dims cell_dim_part= value hash 
dim_string=
cell_id=

for dim in "${dimensions[@]}"; do
  value="${!dim}"
  dim_string+="$dim=$value "
  if [[ ${#value} < 32 && "$value" =~ ^[A-Za-z0-9_\.:\-]+$ ]]; then
    cell_dim_part+="$value,"
  else
    hash=$(echo "$value" | cksum -a md5 | awk '{ print $4 }')
    cell_dim_part+="${hash:0:8},"
  fi
done

if [[ "$cell_dim_part" ]]; then
  cell_dim_part=${cell_dim_part%:}
  cell_id=/$cell_dim_part
  if [[ ${high_volume_cube:-f} == t ]]; then
    hash=$(echo "$cell_dim_part" | cksum -a md5 | awk '{ print $4 }') 
    hash=${hash:0:2}
    cell_id=/$hash/$cell_dim_part
  fi
fi

if [[ "${save_prefix:-}" ]]; then
  eval "${save_prefix}_id=$cell_id"
  eval "${save_prefix}_path=$current_cube"
fi

return 0

}

load_context() {
local f=$1 
local logical_parent=${f%/*}
local physical_parent=$(realpath "$logical_parent")
handler_folders=( )

if [ "${#logical_parent}" -gt 1 ]; then
  if [ "$physical_parent" != "$logical_parent" ]; then
    load_physical_context_before "$physical_parent" || return 1
    load_logical_context_before "$physical_parent" || return 1
  else
    load_physical_context_before "$logical_parent" || return 1
  fi
fi

[ -f "$f/cube-context" ] && source "$f/cube-context"
[ -f "$f/cube-context-after" ] && source "$f/cube-context-after"
[ -d "$f/handlers" ] && handler_folders+=( "$f/handlers" )

if [ "${#logical_parent}" -gt 1 ]; then
  if [ "$physical_parent" != "$logical_parent" ]; then
    load_logical_context_after "$physical_parent" || return 1
    load_physical_context_after "$physical_parent" || return 1
  else
    load_physical_context_after "$logical_parent" || return 1
  fi
fi

return 0
}

load_physical_context_before() {
local f=$1 
local physical_parent=${f%/*}
if [ "${#physical_parent}" -gt 1 ]; then
  load_physical_context_before "$physical_parent" || return 1
fi
[ -f "$f/cube-context" ] && source "$f/cube-context"
return 0
}

load_physical_context_after() {
local f=$1 
local physical_parent=${f%/*}
[ -f "$f/cube-context-after" ] && source "$f/cube-context-after"
[ -d "$f/handlers" ] && handler_folders+=( "$f/handlers" )
if [ "${#physical_parent}" -gt 1 ]; then
  load_physical_context_after "$physical_parent" || return 1
fi
return 0
}

load_logical_context_before() {

local f=$1 
local logical_parent=${f%/*}
local physical_parent=$(realpath "$logical_parent")

if [ "${#logical_parent}" -gt 1 ]; then
  if [ "$physical_parent" != "$logical_parent" ]; then
    load_physical_context_before "$physical_parent" || return 1
    load_logical_context_before "$physical_parent" || return 1
  else
    load_physical_context_before "$logical_parent" || return 1
  fi
fi

[ -f "$f/cube-context" ] && source "$f/cube-context"
return 0

}

load_logical_context_after() {

local f=$1 
local logical_parent=${f%/*}
local physical_parent=$(realpath "$logical_parent")

[ -f "$f/cube-context-after" ] && source "$f/cube-context-after"
[ -d "$f/handlers" ] && handler_folders+=( "$f/handlers" )

if [ "${#logical_parent}" -gt 1 ]; then
  if [ "$physical_parent" != "$logical_parent" ]; then
    load_logical_context_after "$physical_parent" || return 1
    load_physical_context_after "$physical_parent" || return 1
  else
    load_physical_context_after "$logical_parent" || return 1
  fi
fi

return 0

}

gather_dims() {
trace 0 "Gathering dimensions for $current_cube"
local dimension dimension_folder dimension_plural
localize_dim_vars=
begin_function
  if [ -d "$current_cube/dim" ]; then
    begin_for dimension_folder in \
      $(find "$current_cube/dim" -mindepth 1 -maxdepth 1 -type d | sort); doo
      dimension=${dimension_folder##*/}
      if [[ "$dimension" =~ ^[0-9]+- ]]; then
        dimension=${dimension#*-}
      fi
      if [[ ! "$dimension" =~ ^[a-zA-Z0-9_]+$ ]]; then
        err "Invalid dimension name [$dimension] derived from folder $dimension_folder"
        err "Dimensions must only have alphanumeric or _ characters in it."
        fail
      fi
      dimension_plural=${dimension}s
      dimensions+=( $dimension )
      dimension_folders+=( "$dimension_folder" )
      localize_dim_vars+="local $dimension $dimension_plural; "
      if [[ "${!dimensions:-}" ]]; then
        dim_string+="$dimensions=[ ${!dimensions:-} ] "
      else
        dim_string+="$dimension=${!dimension:-} "
      fi
    end_for
  fi
end_function
handle_return
}

