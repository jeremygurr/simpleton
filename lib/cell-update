#!/bin/bash

cell_update() {
trace 0 "Updating cells"
begin_function
  local subject
  begin_while subject in "$@"; doo
    cell_update_array "$subject" || fail
  end_while
end_function
handle_return
}

cell_update_array() {

local current_cell=$1
local parallel_execution=${parallel_execution:-${par:-t}}
trace 0 "Updating array of $current_cell"
begin_function

  if [ ! -d "$current_cell/status" ]; then
    local folder
    # check subfolders for cells
    for folder in $(find $current_cell -mindepth 1 -maxdepth 1 -type d); do
      cell_update_single "$folder" || fail
    done
  fi

  load_status_context "$current_cell" || fail

  if ! normalize_dimensions "$current_cell"; then
    err "Dimension normalization failed. One of the dimensions must be invalid."
    fail
  fi

  cell_update_row_set "$current_cell" "${dimensions[@]}" || fail

end_function
handle_return

}

cell_update_row_set() {

local current_cell=$1; shift
local first_dimension=${1}s; shift
local dimensions_remaining=( "$@" )

local values="${!first_dimension:-}"
trace 0 "Updating rows of $current_cell: $first_dimension=[ $values ]"
begin_function

  if [ ! "$values" ]; then
    err "Missing value for dimension $first_dimension"
    fail
  fi

  values=( $values )
  local value processes
  local parallel=f
  [ "${#values[*]}" -gt 1 -a "$parallel_execution" == t ] && parallel=t

  for value in "${values[@]}"; do
    eval "$first_dimension='$value'"
    if [ "$dimensions_remaining" ]; then
      if [ $parallel == t ]; then
        cell_update_row_set "$current_cell" "${dimensions_remaining[@]}" &
        processes+=" $!"
      else
        cell_update_row_set "$current_cell" "${dimensions_remaining[@]}" || fail
      fi
    else
      if [ $parallel == t ]; then
        cell_update_row_set "$current_cell" "${dimensions_remaining[@]}" &
        cell_update_row "$current_cell" &
        processes+=" $!"
      else
        cell_update_row "$current_cell" || fail
      fi
    fi
  done

  if [ $parallel == t ]; then
    local process
    trace 0 "Waiting for sub processes to complete"
    begin_for process in $processes; doo
      wait $process || fail
    end_for
  fi

end_function
handle_return

}

cell_update_row() {

local current_cell=$1

local dim dim_string=""
for dim in "${dimensions[@]}"; do
  dim=${dim}s
  dim_string+="$dim=[ ${!dim:-} ] "
done
trace 0 "Updating row of $current_cell: $dim_string"

begin_function

  # we need dep phase even if build phase is skipped

  # freshness check first
  local needs_update
  does_cell_need_update || fail
  if [ $needs_update == f ]; then
    trace 0 "Update not needed"
    succeed
  fi

  wait_for_low_load || fail

  # todo: cell needs update if update is possible AND something changed (including deps)
  #   so dep analysis must happen before determining if this cell needs to update
  #   do we need to lock the cell if we are doing dep analysis?

  # each update needs the full dimension vars for each row, the row id for each won't work, 
  #   need to loop over all possibilities

    if [ -d "$current_cell/lock" ]; then
      local lock_timeout=${lock_timeout:-30}
      local lock_fail_code=33
      local return_code
      flock -x -E $lock_fail_code -n "$current_cell/lock" cell_update_after_write_lock
      return_code=$?
      if [ $return_code == $lock_fail_code ]; then
        trace 5 "Waiting for write lock on $current_cell/lock"
        flock -x -E $lock_fail_code -w $lock_timeout "$current_cell/lock" cell_update_after_write_lock || failed_to_get_lock=t
        return_code=$?
        if [ $return_code == $lock_fail_code ]; then
          err "Could not get lock ($current_cell/lock) within time limit of $lock_timeout seconds"
          fail
        elif [ $return_code -gt 0 ]; then
          fail
        fi
      elif [ $return_code -gt 0 ]; then
        fail
      fi
    else
      cell_update_after_write_lock || fail
    fi

end_function
handle_return

}

derive_row_ids() {
# todo: needs to be fixed to support multiple rows and use plural dims
local dimension_count="${#dimensions[*]}" 
if [ $dimension_count -gt 0 ]; then
  local dimension default dimension_with_default
  row_id=
  for dimension_with_default in "${dimensions[@]}"; do
    read dimension default <<<$dimension_with_default
    local var_defined=t
    declare -p "$dimension" &>/dev/null || var_defined=f
    if [ $var_defined == f ]; then
      if [ "$default" ]; then
        eval "$dimension='$default'"
      else
        err "Required var $dimension not defined, and no default was provided."
        fail
      fi
    fi
    if [[ "${!dimension}" =~ [$TAB$NL\ :] ]]; then
      err "Dimension $dimension contains invalid characters: [${!dimension}]. It must not contain white space or colons."
      fail
    fi
    row_id+="${!dimension}:"
  done
  row_id=${row_id%:}
  row_path="/$row_id"
else
  row_id="only"
  row_path=""
fi
}

wait_for_low_load() {
local cell_max_load=${cell_max_load:-10}
local cell_load_wait_timeout=${cell_load_wait_timeout:-600}
local current_load=$(uptime | sed -E 's/.*averages: ([0-9]*).*/\1/')
if [ $current_load -gt $cell_max_load ]; then
  trace 5 "Load average is too high ($current_load > $cell_max_load), waiting until things cool down first."
  local time_waited=0
  while [ $current_load -gt $cell_max_load ]; do
    current_load=$(uptime | sed -E 's/.*averages: ([0-9]*).*/\1/')
    sleep 5; let time_waited+=5
    if [ "$cell_load_wait_timeout" -gt 0 -a $time_waited -ge $cell_load_wait_timeout ]; then
      err "Timed out waiting for cpu load to be low enough. Aborting"
      return 1
    fi
  done
fi
return 0
}

tee_output_to() {
local target=$1
exec 1> >(tee "$target")
exec 2> >(tee -a "$target")
eval "exec $fd_trace> >(tee -a '$target')"
}

untee_output() {
exec 1>&$fd_original_out
exec 2>&$fd_original_err
eval "exec $fd_trace>&$fd_original_trace"
}

cell_update_after_write_lock() {
begin_function

  load_update_context "$current_cell" || fail
  init_status || fail
  new_status begin_update || fail
  if [ -d "$current_cell/log" ]; then
    tee_output_to "$current_cell/log/current"
  fi
  local update_successful=f
  
  local parallel_execution=${parallel_execution:-${parallel:-t}}
  # each dependency, in parallel
  # validate parameters (some require any)
  # use ionice and nice
    # is it -any?
    # yes: choose which to lock or update
    # does it need update?
    # yes: update cell
    # update down if missing
    # read lock
  # wait for parallel dependencies
  # update status
  # execute local update

  if [ $update_successful == t ]; then
    trace 0 "Update successful."
    new_status succeeded || fail
  else
    trace 0 "Update failed."
    new_status failed || fail
  fi

  if [ -d "$current_cell/log" ]; then
    untee_output
    if [ $update_successful == t ]; then
      mv "$current_cell/log/current_cell" "$current_cell/log/last_success"
    else
      mv "$current_cell/log/current_cell" "$current_cell/log/last_failure"
    fi
  fi

end_function
handle_return
}

init_status() {
mkdir -p "$current_cell/status"
rm "$current_cell/status/begin_update"
}

new_status() {
touch "$current_cell/status/$1"
}

does_cell_need_update() {
begin_function

  needs_update=f
  if [ -d "$current_cell/out$row_path" ]; then

    # nothing needs to be done in execution phase if execute function isn't defined
    type execute &>/dev/null || succeed

    if [ -d "$current_cell/in" ]; then
      if [ "$current_cell/in" -nt "$current_cell/out$row_path" ]; then
        trace 0 "Local changes were made, needs update"
        needs_update=t
        succeed
      fi
    fi

    if [ -d "$current_cell/up" ]; then
      if [ "$current_cell/up" -nt "$current_cell/out$row_path" ]; then
        trace 0 "Upstream changes were made, needs update"
        needs_update=t
        succeed
      fi
    fi

    if [ "${fresh:-}" ]; then
      local fresh_seconds
      convert_to_seconds $fresh fresh_seconds || fail
      local fresh_cutoff=$((EPOCHSECONDS-fresh_seconds))
      local out_timestamp=$(date -r "$current_cell/out$row_path" +%s)
      if [ $out_timestamp -lt $fresh_cutoff ]; then
        trace 0 "Freshness requirement ($fresh) not met, needs update"
        needs_update=t
        succeed
      fi
    fi

  fi

end_function
handle_return
}
