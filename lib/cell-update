#!/bin/bash

cube_update() {

local current_cube=$1
# set this before calling this function to maintain a read lock even
#   after this update completes. Used for upstream dependency locking. 
local keep_read_locks=${keep_read_locks:-f}
local keep_write_locks=${keep_write_locks:-f}

if [[ ! -f "$current_cube/cube-contexxt" ]]; then
  err "cube_update called on $current_cube which is not a cube"
  return 1
fi

local parallel_default=t
[ $debug == t ] && parallel_default=f
local parallel_execution=${parallel_execution:-${par:-$parallel_default}}
local save_cell_id_to_var=${save_cell_id_to_var:-} save_cell_path_to_var=${save_cell_path_to_var:-}
local dimensions=() dimension_folders=() localize_dim_vars dim_string="" fd

# need to collect dimensions even though we haven't expanded the members yet
gather_dims || return 1

trace 0 "Updating cube $current_cube $dim_string"

begin_function

  if [[ "$current_cube" -nt "$current_cube/cube-context" ]]; then
    touchup_cube || fail
  fi

  eval "$localize_dim_vars" || fail

  if [ ${#dimensions[*]} == 0 ]; then
    if [[ -d $current_cube/lock && ($keep_read_locks == t || $keep_write_locks == t) ]]; then
      exec {fd}<$current_cube/lock
    fi
    get_cell_id || return 1
    outer_lock_fd=$fd cell_update "$current_cube" || fail
  else
    cube_update_pivot 0 || fail
  fi

end_function
handle_return

}

gather_dims() {
trace 0 "Gathering dimensions for $current_cube"
local dimension dimension_folder dimension_plural
begin_function
  if [ -d "$current_cube/dim" ]; then
    begin_for dimension_folder in 
      $(find "$current_cube/dim" -mindepth 1 -maxdepth 1 -type d | sort); doo
      dimension=${dimension_folder##*/}
      if [[ "$dimension" =~ ^[0-9]+- ]]; then
        dimension=${dimension#*-}
      fi
      if [[ ! "$dimension_folder" =~ ^[a-zA-Z0-9_]+$ ]]; then
        err "Invalid dimension name [$dimension] derived from folder $dimension_folder"
        err "Dimensions must only have alphanumeric or _ characters in it."
        fail
      fi
      dimension_plural=${dimension}s
      dimensions+=( $dimension )
      dimension_folders+=( "$dimension_folder" )
      localize_dim_vars+="local $dimension $dimension_plural; "
      if [[ "${!dimensions:-}" ]]; then
        dim_string+="$dimensions=[ ${!dimensions:-} ] "
      else
        dim_string+="$dimension=${!dimension:-} "
      fi
    end_for
  fi
end_function
handle_return
}

touchup_cube() {
trace 0 "Touching up $current_cube"
local f
begin_function
  begin_for f in up res down in out tmp log lock key status; doo
    if [ -f "$current_cube/$f" ]; then
      rm "$current_cube/$f" || fail
      mkdir "$current_cube/$f" || fail
    fi
  end_for
  touch "$current_cube/cube-context"
end_function
handle_return
}

# should only be called if there are dimensions remaining to be pivoted. Otherwise cell_update should be called.
cube_update_pivot() {

local index=$1
local dim=${dimensions[$index]} 
local dim_folder=${dimension_folders[$index]}

trace 0 "Pivoting $current_cube: $dim"
begin_function

  if [[ ! -d "$dim_folder" ]]; then
    err "Internal error: cube_update_pivot was called with an index which doesn't corrospond with a dimension folder: $dim_folder"
    fail
  fi

  cube_update "$dim_folder" || fail
  if [[ ! -f "$dim_folder/out/functions" ]]; then
    err "Missing functions file in $dimension_folder/out. It must contain the expand_dim function."
    fail
  fi
  source "$dim_folder/out/functions" || fail
  expand_dim $dim || fail
  local dims=${dim}s
  local values=( ${!dims:-} )

  if [[ ! "$values" ]]; then
    err "Missing value for dimension $dim"
    fail
  fi

  local value processes
  local parallel=f
  if [[ "${#values[*]}" > 1 && "$parallel_execution" == t ]]; then
    parallel=t
    wait_for_low_load || fail
  fi

  begin_for value in "${values[@]}"; doo
    eval "$dim='$value'"
    if [[ ${#dim[*]} > $((index + 1)) ]]; then
      if [[ $parallel == t ]]; then
        cube_update_pivot $((index + 1)) &
        processes+=" $!"
      else
        cube_update_pivot $((index + 1)) || fail
      fi
    else
      local fd=
      local cell_id dim_string
      get_cell_id || fail
      if [[ -d $current_cube/lock && ($keep_read_locks == t || $keep_write_locks == t) ]]; then
        exec {fd}<$current_cube/lock$cell_id || fail
      fi
      if [[ $parallel == t ]]; then
        outer_lock_fd=$fd cell_update "$current_cube" &
        processes+=" $!"
      else
        outer_lock_fd=$fd cell_update "$current_cube" || fail
      fi
    fi
  end_for

  wait_for_sub_processes || fail

end_function
handle_return

}

wait_for_sub_processes() {
if [[ $parallel == t && "$processes" ]]; then
  trace 0 "Waiting for sub processes to complete"
  local process
  for process in $processes; do
    wait $process &>/dev/null
    if [[ $? > 0 && $? < 127 ]]; then
      trace 0 "Subprocess $process failed to terminate successfully"
      return 1
    fi
  done
fi
}

select_any_cube() {
local current_cube=$1
trace 0 "Testing 'any' cube $current_cube"
begin_function

  init_and_load_status_context_a
  validate_dims || fail
  local needs_update
  does_cube_need_update || fail
  if [ $needs_update == t ]; then
    trace 0 "Update needed"
    fail
  fi

end_function
handle_return
}

update_any_cube() {
local current_cube=$1
trace 0 "Updating 'any' cube $current_cube"
begin_function
  init_and_load_status_context_a
  cube_update_array "$current_cube" || fail
end_function
handle_return
}

cell_get_resources() {
trace 0 "Getting resources for $current_cube"
begin_function

  local res dep_fd
  local parallel=f processes
  local parallel_resources=( $(
    find "$current_cube/res" -mindepth 1 -maxdepth 1 -type d \
      -not -regex "$current_cube/res/[0-9]+-.*" 
    ) )
  local serial_resources=( $(
    find "$current_cube/res" -mindepth 1 -maxdepth 1 -type d \
      -regex "$current_cube/res/[0-9]+-.*" \
    | sort) )

  local total_parallel=${#parallel_resources[*]}
  [[ "$sequential_resources" ]] && let total_parallel++

  if [[ $total_parallel > 1 && $parallel_execution == t ]]; then
    parallel=t
    wait_for_low_load || fail
  fi

  local saved_id= saved_path= res_name
  begin_for res in ${parallel_resources[*]}; doo
    update_resource "$res" &
  end_for

  if [[ $parallel == t ]]; then
    update_serial_resources &
  else
    update_serial_resources || fail
  fi

  wait_for_sub_processes || fail

end_function
handle_return
}

update_resource() {
local res=$1
save_cell_id_to_var=saved_id save_cell_path_to_var=saved_path keep_write_locks=t cube_update $res || return 1
local res_name=${res##*/}
# This can be used in later code to fetch which resource was allocated
eval "res_id_$res_name=$saved_id"
eval "res_path_$res_name=$saved_path"
return 0
}

update_serial_resources() {
begin_for res in ${serial_resources[*]}; doo
  update_resource $res || return 1
end_for
return 0
}

cell_update_deps() {
trace 0 "Updating upstream cells of $current_cube"
begin_function

  local dep 
  local parallel=f processes
  local parallel_deps=( $(
    find "$current_cube/up" -mindepth 1 -maxdepth 1 -type d \
      -not -regex "$current_cube/up/[0-9]+-.*" 
    ) )
  local serial_deps=( $(
    find "$current_cube/up" -mindepth 1 -maxdepth 1 -type d \
      -regex "$current_cube/up/[0-9]+-.*" \
    | sort) )

  local total_parallel=${#parallel_deps[*]}
  [[ "$sequential_deps" ]] && let total_parallel++

  if [[ $total_parallel > 1 && $parallel_execution == t ]]; then
    parallel=t
    wait_for_low_load || fail
  fi

  begin_for dep in ${parallel_deps[*]}; doo
    update_dep "$dep" &
  end_for

  if [[ $parallel == t ]]; then
    update_serial_deps &
  else
    update_serial_deps || fail
  fi

  wait_for_sub_processes || fail

end_function
handle_return
}

update_serial_deps() {
begin_for dep in "${serial_deps[@]}"; doo
  update_dep "$dep" || return 1
end_for
return 0
}

update_dep() {
local dep=$1
save_cell_id_to_var=saved_id save_cell_path_to_var=saved_path keep_read_locks=t cube_update $dep || return 1
local dep_name=${dep##*/}
# This can be used in later code to fetch which dep was found (may be multiple possibilities if 'any' is used)
eval "dep_id_$dep_name=$saved_id"
eval "dep_path_$dep_name=$saved_path"
return 0
}

get_read_lock() {
local lock_path=$1
local timeout=${2:-$lock_timeout}
flock -s -w $lock_timeout $lock_fd || {
  err "Failed to get read lock for $lock_path within $timeout seconds"
  return 1
  }
}

get_write_lock() {
local lock_path=$1
local timeout=${2:-$lock_timeout}
flock -e -w $lock_timeout $lock_fd || {
  err "Failed to get write lock for $lock_path within $timeout seconds"
  return 1
  }
}

unlock() {
flock -u $lock_fd
}

write_persist_file() {
  echo "
update_id=$update_id
cooldown_delay=$cooldown_delay
consecutive_failures=$consecutive_failures
" >$status_path/persist || fail
}

maybe_apply_cooldown() {
begin_function
  # If cell recently failed, wait until cooldown period is complete
  if [[ $consecutive_failures > 0 ]]; then
    get_cooldown_delay || fail
    if [[ $cooldown_delay > 0 ]]; then
      trace 0 "Too many errors have occurred, waiting for cooldown period of $cooldown_delay seconds"
      new_stage cooldown || fail
      sleep $cooldown_delay
    fi
  else
    cooldown_delay=1
  fi
end_function
handle_return
}

# produces: cell_id, dim_string
get_cell_id() {
local dim dims cell_dim_part value
# TODO compute hashed path
for dim in "${dimensions[@]}"; do
  value="${!dim}"
  dim_string+="$dim=$value "
  cell_dim_part+="$value:"
done

if [[ "$cell_dim_part" ]]; then
  # TODO validate dim part, no spaces or / or : or other special chars
  cell_dim_part=${cell_dim_part%:}
  cell_id=/$cell_dim_part
  if [[ ${high_volume_cube:-f} == t ]]; then
    local hash=$(echo "$cell_dim_part" | cksum) 
    hash=${hash:0:2}
    cell_id+=/$hash
  fi
fi

if [[ "${save_cell_id_to_var:-}" ]]; then
  eval "$save_cell_id_to_var=$cell_id"
  save_cell_id_to_var=
fi

if [[ "${save_cell_path_to_var:-}" ]]; then
  eval "$save_cell_path_to_var=$current_cube"
  save_cell_path_to_var=
fi

return 0
}

# Notice that it has parentheses after function name instead of braces. This means it launches in a
# subshell, localizing the variables and function changes
cell_update_inner() (

local current_cube=$1; shift
local cell_id=$1; shift
local dim_string=$1; shift

local update_id stage_start_time previous_stage

local in_path= lock_path= log_path= status_path= out_path= up_path= res_path=
local lock_fd

trace 0 "Updating cell $current_cube $dim_string"

begin_function

  init_and_load_context_a

  if [[ -d $current_cube/in ]]; then
    in_path=$current_cube/in$cell_id
    [[ ! -f $in_path ]] && in_path=$current_cube/in
  fi

  if [[ -d $current_cube/lock ]]; then
    lock_path=$current_cube/lock$cell_id
    [[ ! -f $lock_path ]] && { touch $lock_path || fail; }
    if [[ "$outer_lock_fd" ]]; then
      lock_fd=$outer_lock_fd
    else
      exec {lock_fd}<>"$lock_path" || fail
    fi
  fi

  if [[ -d $current_cube/log ]]; then
    log_path=$current_cube/log$cell_id
    [[ ! -d $log_path ]] && { mkdir $log_path || fail; }
    tee_output_to $log_path/current-update-log
  fi

  if [[ -d $current_cube/status ]]; then
    status_path=$current_cube/status$cell_id
    [[ ! -d $status_path ]] && { mkdir $status_path || fail; }
  fi

  if [[ -d $current_cube/out ]]; then
    out_path=$current_cube/out$cell_id
    if [[ ! -d $out_path ]]; then
      mkdir $out_path || fail
      touch -t 197001010000 $out_path || fail
    fi
  fi

  if [[ -d $current_cube/up ]]; then
    up_path=$current_cube/up$cell_id
    if [[ ! -d $up_path ]]; then
      up_path=$current_cube/up || fail
    fi
  fi

  if [[ -d $current_cube/res ]]; then
    res_path=$current_cube/res$cell_id
    if [[ ! -d $res_path ]]; then
      res_path=$current_cube/res || fail
    fi
  fi

  init_stage || fail
  new_stage begin-update || fail

  if [[ "$status_path" ]]; then

    local consecutive_failures=${consecutive_failures:-0}
    [[ -f "$status_path/persist" ]] && { source "$status_path/persist" || fail; }

    if [[ "${update_id:-}" ]]; then
      let update_id++
    else
      update_id=1000
    fi

    maybe_apply_cooldown || fail
    write_persist_file || fail

  else
    update_id=1000
  fi

  local lock_timeout=${lock_timeout:-30}

  if [[ "$lock_path" ]]; then
    trace 0 "Getting read lock for cell"
    new_stage read-lock-cell || fail
    get_read_lock "$lock_path" || fail
  fi

  trace 0 "Checking if update is needed"
  new_stage check-needs-update || fail
  # freshness check first
  local needs_update
  does_cube_need_update || fail
  if [[ $needs_update == f ]]; then
    trace 0 "Update not needed"
    succeed
  fi

  if [[ "$up_path" ]]; then
    new_stage update-deps || fail
    cell_update_deps || fail
  fi

  new_stage write-lock || fail
  if [[ "$lock_path" ]]; then
    trace 0 "Getting write lock for cell"
    new_stage write-lock-cell || fail
    get_write_lock "$lock_path" || fail
  fi

  # TODO: obtain resources: keep_write_locks, res_id=any
  #   use realpath to fetch cell_id of allocated cell
  if [[ "$res_path" ]]; then
    trace 0 "Getting resources for cell"
    new_stage get-resources || fail
    cell_get_resources "$res_path" || fail
  fi

  new_stage load-update-context || fail
  init_and_load_update_context_a

  local in_path="$current_cube/in"
  [ -n "$cell_id" ] && [ -d "$current_cube/in$cell_id" ] && in_path="$current_cube/in$cell_id"

  # TODO: only use tmp path here if folder exists, otherwise use system tmp folder
  local tmp_path="$current_cube/tmp$cell_id"
  if [ -d "$tmp_path" ]; then
    rm -rf "$tmp_path" || fail
  fi
  mkdir "$tmp_path" || fail

  mkdir -p "$out_path.new" || fail

  local need_decrypt file
  begin_for file in $(find "$in_path" -name '*.crypt' -type f); doo
    file=${file#$in_path}
    file=${file%.crypt}
    if [ -f "$out_path/$file" ]; then
      cp "$out_path/$file" "$out_path.new/$file" || fail
    else
      need_decrypt+="$file "
    fi
  end_for

  if [ "$need_decrypt" ]; then
    new_stage decrypt || fail
    begin_for file in $need_decrypt; doo
      decrypt_file "$in_path/$file.crypt" "$out_path.new/$file" || fail
    end_for
  fi

  new_stage execute-update || fail

  local start_time=$EPOCHSECONDS
  local update_successful=f
  execute_update && update_successful=t
  local duration_of_update=$((EPOCHSECONDS-start_time))
  local success_string=good
  [ $update_successful == f ] && success_string=bad
  echo "start:$start_time duration:$duration_of_update from:$called_from result:$success_string" >>$log_path/history || fail

  mv $log_path/update-log-current $log_path/update-log-$update_id || fail
  if [ $update_successful == t ]; then

    trace 0 "Update successful."
    new_stage succeeded || fail

    if [ -d "$out_path.new" -a $update_successful == t ]; then
      if ! diff -r "$out_path" "$out_path.new" >/dev/null; then
        [ -d "$out_path.old" ] && rm -rf "$out_path.old" 2>/dev/null
        mv "$out_path" "$out_path.old" || fail
        mv "$out_path.new" "$out_path" || fail
        mv "$current_cube/status$cell_id/current" "$current/status$cell_id/last-success-changed" || fail
      else
        rm -rf "$out_path.new" || fail
        mv "$current_cube/status$cell_id/current" "$current/status$cell_id/last-success-not-changed" || fail
      fi
    fi

    touch -d @$start_time "$out_path" || fail

    if [ -d "$current_cube/log" ]; then
      untee_output
      ln -s $log_path/update-log-last-success $log_path/update-log-$update_id || fail
      # TODO: save all logs if debug folder exists
    fi

    # TODO: push update to dependencies
    # TODO: record successful updates in execution log (cell, update id and timestamp)

    if [ -d "$tmp_path" ]; then
      rm -rf "$tmp_path" || fail
    fi

    consecutive_failures=0
    write_persist_file

  else

    trace 0 "Update failed."
    new_stage failed || fail

    mv "$current_cube/status$cell_id/current" "$current/status$cell_id/last-failure" || fail

    if [ -d "$current_cube/log" ]; then
      untee_output
      ln -s $log_path/update-log-last-failure $log_path/update-log-$update_id || fail
      # TODO: save all logs if debug folder exists
    fi
    # TODO: record failed updates in execution log (cell, update id and timestamp)

    let consecutive_failures++
    write_persist_file

  fi

  if [[ "$outer_lock_fd" ]]; then
    if [[ $keep_write_locks == f ]]; then
      # convert back to read lock so it doesn't change when downstream update is proceeding
      get_read_lock "$lock_path" || fail
    fi
  else
    unlock || fail
  fi

end_function
handle_return

)

# not used?
derive_row_ids() {
# todo: needs to be fixed to support multiple rows and use plural dims
local dimension_count="${#dimensions[*]}" 
if [ $dimension_count -gt 0 ]; then
  local dimension default dimension_with_default
  row_id=
  for dimension_with_default in "${dimensions[@]}"; do
    read dimension default <<<$dimension_with_default
    local var_defined=t
    declare -p "$dimension" &>/dev/null || var_defined=f
    if [ $var_defined == f ]; then
      if [ "$default" ]; then
        eval "$dimension='$default'"
      else
        err "Required var $dimension not defined, and no default was provided."
        fail
      fi
    fi
    if [[ "${!dimension}" =~ [$TAB$NL\ :] ]]; then
      err "Dimension $dimension contains invalid characters: [${!dimension}]. It must not contain white space or colons."
      fail
    fi
    row_id+="${!dimension}:"
  done
  row_id=${row_id%:}
  cell_id="/$row_id"
else
  row_id="only"
  cell_id=""
fi
}

wait_for_low_load() {
local cube_max_load=${cube_max_load:-10}
local cube_load_wait_timeout=${cube_load_wait_timeout:-600}
local current_load=$(uptime | sed -E 's/.*averages: ([0-9]*).*/\1/')
if [ $current_load -gt $cube_max_load ]; then
  trace 0 "Load average is too high ($current_load > $cube_max_load), waiting until things cool down first."
  local time_waited=0
  while [ $current_load -gt $cube_max_load ]; do
    current_load=$(uptime | sed -E 's/.*averages: ([0-9]*).*/\1/')
    sleep 5; let time_waited+=5
    if [ "$cube_load_wait_timeout" -gt 0 -a $time_waited -ge $cube_load_wait_timeout ]; then
      err "Timed out waiting for cpu load to be low enough. Aborting"
      return 1
    fi
  done
fi
return 0
}

tee_output_to() {
local target=$1
exec 1> >(tee "$target")
exec 2> >(tee -a "$target")
eval "exec $fd_trace> >(tee -a '$target')"
}

untee_output() {
exec 1>&$fd_original_out
exec 2>&$fd_original_err
eval "exec $fd_trace>&$fd_original_trace"
}

init_stage() {
previous_stage=
start_time=
}

new_stage() {
local stage=$1
if [ "${previous_stage:-}" ]; then
  trace 5 "Finished stage $previous_stage (took $(echo '$EPOCHSECONDS - $stage_start_time' | bc) seconds)"
fi
echo "$stage $EPOCHSECONDS" >>"$log_path/current-stages"
trace 5 "Starting stage $stage"
stage_start_time=$EPOCHSECONDS
previous_stage=$stage
}

does_cube_need_update() {
begin_function

  needs_update=t

  [[ ! "$out_path" ]] && succeed
  
  if [[ "$in_path" ]]; then
    if [[ "$in_path" -nt "$out_path" ]]; then
      trace 0 "Local changes were made, needs update"
      succeed
    fi
  fi

  # nothing needs to be done in execution phase if execute_update function isn't defined
  type execute_update &>/dev/null || succeed

  if [[ "$up_path" ]]; then
    if [[ "$up_path" -nt "$out_path" ]]; then
      trace 0 "Upstream changes were made, needs update"
      succeed
    fi
  fi

  if [ "${fresh:-}" ]; then
    local fresh_seconds
    convert_to_seconds $fresh fresh_seconds || fail
    local fresh_cutoff=$((EPOCHSECONDS-fresh_seconds))
    local out_timestamp=$(date -r "$out_path" +%s)
    if [ $out_timestamp -lt $fresh_cutoff ]; then
      trace 0 "Freshness requirement ($fresh) not met, needs update"
      succeed
    fi
  fi

  needs_update=f

end_function
handle_return
}
