#!/bin/bash

cell_update() {
trace 0 "Updating cells"
begin_function
  local subject
  begin_while subject in "$@"; doo
    cell_update_array "$subject" || fail
  end_while
end_function
handle_return
}

cell_update_array() {

local current_cell=$1
local parallel_execution=${parallel_execution:-${par:-t}}
trace 0 "Updating array of $current_cell"
begin_function

  if [ ! -d "$current_cell/status" ]; then
    local folder
    # check subfolders for cells
    for folder in $(find "$current_cell" -mindepth 1 -maxdepth 1 -type d | sort); do
      # todo: support parallel execution here?
      cell_update_row_set "$folder" "${dimensions[@]}" || fail
    done
  else
    init_and_load_status_context_a
    cell_update_row_set "$current_cell" "${dimensions[@]}" || fail
  fi

end_function
handle_return

}

cell_update_row_set() {

local current_cell=$1; shift
local first_dimension=${1}s; shift
local dimensions_remaining=( "$@" )

local values="${!first_dimension:-}"
trace 0 "Updating rows of $current_cell: $first_dimension=[ $values ]"
begin_function

  if [ ! "$values" ]; then
    err "Missing value for dimension $first_dimension"
    fail
  fi

  values=( $values )
  local value processes
  local parallel=f
  [ "${#values[*]}" -gt 1 -a "$parallel_execution" == t ] && parallel=t

  begin_for value in "${values[@]}"; doo
    eval "$first_dimension='$value'"
    if [ "$dimensions_remaining" ]; then
      if [ $parallel == t ]; then
        cell_update_row_set "$current_cell" "${dimensions_remaining[@]}" &
        processes+=" $!"
      else
        cell_update_row_set "$current_cell" "${dimensions_remaining[@]}" || fail
      fi
    else
      if [ $parallel == t ]; then
        cell_update_row "$current_cell" &
        processes+=" $!"
      else
        cell_update_row "$current_cell" || fail
      fi
    fi
  end_for

  wait_for_sub_processes || fail

end_function
handle_return

}

wait_for_sub_processes() {
[ $parallel == t ] && trace 0 "Waiting for sub processes to complete"
if [ $parallel == t ]; then
  local process
  for process in $processes; do
    wait $process &>/dev/null
    if [ $? -gt 0 -a $? -lt 127 ]; then
      trace 0 "Subprocess failed to terminate successfully"
      return 1
    fi
  done
fi
}

select_any_cell() {
local current_cell=$1
trace 0 "Testing 'any' cell $current_cell"
begin_function

  init_and_load_status_context_a
  local needs_update
  does_cell_need_update || fail
  if [ $needs_update == t ]; then
    trace 0 "Update needed"
    fail
  fi

end_function
handle_return
}

update_any_cell() {
local current_cell=$1
trace 0 "Updating 'any' cell $current_cell"
begin_function
  init_and_load_status_context_a
  cell_update_row "$current_cell" || fail
end_function
handle_return
}

cell_update_deps() {
trace 0 "Updating subs of $current_cell"
begin_function

  local dep
  local parallel=f processes
  [ "${#values[*]}" -gt 1 -a "$parallel_execution" == t ] && parallel=t

  local any_folder
  begin_for any_folder in $(find "$current_cell/up" -name '*\?' -mindepth 1 -maxdepth 1 -type d | sort); doo
    
    # check if any cells are already complete
    local any_selected=
    local options=$(find "$any_folder" -mindepth 1 -maxdepth 1 -type d | sort)
    begin_for dep in $options; doo
      select_any_cell "$dep" && { any_selected=$dep; break; }
    end_for

    # of those that are valid, try to update one by one until successful
    if [ ! "${any_selected:-}" ]; then
      begin_for dep in $options; doo
        update_any_cell "$dep" && { any_selected=$dep; break; }
      end_for
    fi

    # link any cell to parent folder
    if [ "${any_selected:-}" ]; then
      local selected_folder=$any_selected
      [[ $selected_folder =~ .*/(.*/.*) ]] || fail
      selected_folder=${BASH_REMATCH[1]}
      ln -sf "$selected_folder" "$current_cell/up/${any_folder%?}" || fail
    else
      trace -5 "Failed to find valid dependency for $any_folder"
      fail
    fi

  end_for

  begin_for dep in $(find "$current_cell/up" -not -name '*\?' -mindepth 1 -maxdepth 1 -type d | sort); doo
    local down_path="$dep/down/${current_cell##*/}"
    if [ ! -e "$down_path" ]; then
      ln -sf "$current_cell" "$down_path" || fail
    elif [ "$(realpath "$down_path")" != "$current_cell" ]; then
      local variant=2
      begin_while true; doo
        if [ ! -e "$down_path$variant" ]; then
          ln -sf "$current_cell" "$down_path$variant" || fail
          break
        elif [ "$(realpath "$down_path$variant")" == "$current_cell" ]; then
          break
        fi
        let variant++
      end_while
    fi

    if [ $parallel == t ]; then
      cell_update_row "$dep" &
      processes+=" $!"
    else
      cell_update_row "$dep" || fail
    fi
  end_for

  wait_for_sub_processes || fail

end_function
handle_return
}

read_lock_deps() {
trace 0 "Obtaining read locks for subs of $current_cell"
begin_function

  local dep lock_fd
  begin_for dep in $(find "$current_cell/up" -mindepth 1 -maxdepth 1 -not -name '*\?' -type d | sort); doo
    init_and_load_status_context_a
    if [ -d "$dep/lock" ]; then
      exec {lock_fd}<"$dep/lock" || fail
      flock -s -w $lock_timeout $lock_fd || {
        err "Failed to get read lock for dep $dep of $current_cell"
        fail
        }
    fi
  end_for

end_function
handle_return
}

write_lock_cell() {
trace 0 "Obtaining write lock for $current_cell"
begin_function

  local lock_fd
  exec {lock_fd}<"$current_cell/lock" || fail
  flock -x -w $lock_timeout $lock_fd || {
    err "Failed to get write lock for $current_cell"
    fail
    }

end_function
handle_return
}

cell_update_row() {

local current_cell=$1

local dim dim_string=""
for dim in "${dimensions[@]}"; do
  dim=${dim}s
  dim_string+="$dim=[ ${!dim:-} ] "
done
trace 0 "Updating row of $current_cell: $dim_string"

begin_function

  # out folder must exist
  local out_path="$current_cell/out$row_path"
  if [ ! -d "$out_path" ]; then
    mkdir -p "$out_path" || fail
    touch -t 197001010000 "$out_path" || fail
  fi

  # freshness check first
  local needs_update
  does_cell_need_update || fail
  if [ $needs_update == f ]; then
    trace 0 "Update not needed"
    succeed
  fi

  local lock_timeout=${lock_timeout:-30}

  local read_locks=''
  if [ -d "$current_cell/up" ]; then
    cell_update_deps || fail
    read_lock_deps || fail
  fi

  wait_for_low_load || fail
  if [ -d "$current_cell/lock" ]; then
    write_lock_cell || fail
  fi

  init_and_load_update_context_a
  local start_time=$EPOCHSECONDS
  execute_update || fail
  touch -d @$start_time "$out_path" || fail

end_function
handle_return

}

derive_row_ids() {
# todo: needs to be fixed to support multiple rows and use plural dims
local dimension_count="${#dimensions[*]}" 
if [ $dimension_count -gt 0 ]; then
  local dimension default dimension_with_default
  row_id=
  for dimension_with_default in "${dimensions[@]}"; do
    read dimension default <<<$dimension_with_default
    local var_defined=t
    declare -p "$dimension" &>/dev/null || var_defined=f
    if [ $var_defined == f ]; then
      if [ "$default" ]; then
        eval "$dimension='$default'"
      else
        err "Required var $dimension not defined, and no default was provided."
        fail
      fi
    fi
    if [[ "${!dimension}" =~ [$TAB$NL\ :] ]]; then
      err "Dimension $dimension contains invalid characters: [${!dimension}]. It must not contain white space or colons."
      fail
    fi
    row_id+="${!dimension}:"
  done
  row_id=${row_id%:}
  row_path="/$row_id"
else
  row_id="only"
  row_path=""
fi
}

wait_for_low_load() {
local cell_max_load=${cell_max_load:-10}
local cell_load_wait_timeout=${cell_load_wait_timeout:-600}
local current_load=$(uptime | sed -E 's/.*averages: ([0-9]*).*/\1/')
if [ $current_load -gt $cell_max_load ]; then
  trace 5 "Load average is too high ($current_load > $cell_max_load), waiting until things cool down first."
  local time_waited=0
  while [ $current_load -gt $cell_max_load ]; do
    current_load=$(uptime | sed -E 's/.*averages: ([0-9]*).*/\1/')
    sleep 5; let time_waited+=5
    if [ "$cell_load_wait_timeout" -gt 0 -a $time_waited -ge $cell_load_wait_timeout ]; then
      err "Timed out waiting for cpu load to be low enough. Aborting"
      return 1
    fi
  done
fi
return 0
}

tee_output_to() {
local target=$1
exec 1> >(tee "$target")
exec 2> >(tee -a "$target")
eval "exec $fd_trace> >(tee -a '$target')"
}

untee_output() {
exec 1>&$fd_original_out
exec 2>&$fd_original_err
eval "exec $fd_trace>&$fd_original_trace"
}

cell_update_after_write_lock() {
begin_function

  load_update_context "$current_cell" || fail
  init_status || fail
  new_status begin_update || fail
  if [ -d "$current_cell/log" ]; then
    tee_output_to "$current_cell/log/current"
  fi
  local update_successful=f
  
  local parallel_execution=${parallel_execution:-${parallel:-t}}
  # each dependency, in parallel
  # validate parameters (some require any)
  # use ionice and nice
    # is it -any?
    # yes: choose which to lock or update
    # does it need update?
    # yes: update cell
    # update down if missing
    # read lock
  # wait for parallel dependencies
  # update status
  # execute local update

  if [ $update_successful == t ]; then
    trace 0 "Update successful."
    new_status succeeded || fail
  else
    trace 0 "Update failed."
    new_status failed || fail
  fi

  if [ -d "$current_cell/log" ]; then
    untee_output
    if [ $update_successful == t ]; then
      mv "$current_cell/log/current_cell" "$current_cell/log/last_success"
    else
      mv "$current_cell/log/current_cell" "$current_cell/log/last_failure"
    fi
  fi

end_function
handle_return
}

init_status() {
mkdir -p "$current_cell/status"
rm "$current_cell/status/begin_update"
}

new_status() {
touch "$current_cell/status/$1"
}

does_cell_need_update() {
begin_function

  needs_update=f

  # nothing needs to be done in execution phase if execute function isn't defined
  type execute &>/dev/null || succeed

  if [ -d "$current_cell/in" ]; then
    if [ "$current_cell/in" -nt "$current_cell/out$row_path" ]; then
      trace 0 "Local changes were made, needs update"
      needs_update=t
      succeed
    fi
  fi

  if [ -d "$current_cell/up" ]; then
    if [ "$current_cell/up" -nt "$current_cell/out$row_path" ]; then
      trace 0 "Upstream changes were made, needs update"
      needs_update=t
      succeed
    fi
  fi

  if [ "${fresh:-}" ]; then
    local fresh_seconds
    convert_to_seconds $fresh fresh_seconds || fail
    local fresh_cutoff=$((EPOCHSECONDS-fresh_seconds))
    local out_timestamp=$(date -r "$current_cell/out$row_path" +%s)
    if [ $out_timestamp -lt $fresh_cutoff ]; then
      trace 0 "Freshness requirement ($fresh) not met, needs update"
      needs_update=t
      succeed
    fi
  fi

end_function
handle_return
}
