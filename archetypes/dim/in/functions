#!/bin/bash

dim_description='The environment (e.g. e1, e2)'
multi_possibilities='all us india'
possibilities='e1 e2 e3'

# input: value result_var
# output: *result_var
expand_member() {
local result=

case "$value" in
  e3*)
    result=e3
  ;;
  e2*)
    result=e2
  ;;
  e1)
    result=e1
  ;;
esac

eval "$result_var='$result'"
}

