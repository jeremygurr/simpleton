#!/bin/bash
set -u

source $SIMPLETON_REPO/lib/pre-bash "$0" "$@"
set "${real_params[@]}"; shift

optional_var trace           3             # 0 means no tracing output, higher numbers increases verbosity of tracing

source $SIMPLETON_REPO/lib/post-bash
source $SIMPLETON_REPO/lib/cell-common

command=${1:-help}; shift

parameters=( "$@" )

load_subjects() {
  subjects=()
  local subject 
  for subject in "${parameters[@]}"; do
    #subject=$(realpath "$subject")
    subjects+=( "$subject" )
  done

  if [[ ! "${subjects:-}" ]]; then
    subjects=( $PWD )
  fi
}

called_from=cli

show_usage() {
  warn "Usage: dna {command} [{parameters}]"
  warn "  commands:"
  warn "    add [{path to cell(s)}]                 add a part to an existing cell"
  warn "                                            part={up|res|log|...} use_id={t|f} values=' ... '"
  warn "    clone {from} {to}..                     clones a cell from one location to a new one"
  warn "    edit [{path to file(s) in cell(s)}]     edit a file in an existing cell, updating and encrypting as needed"
  warn "    link {from} {to}..                      link a cell from one location to a new one"
  warn "    move {from}.. {to}                      move a cell from one location to a new one"
  warn "    new [{path to cell(s)}]                 create new cells"
  warn "                                            type={min|standard|...}"
}

load_subjects || exit 1
case $command in 
  clone)
    if [[ ${#subjects[*]} -lt 2 ]]; then
      err "clone command must be followed by 2 parameters"
      show_usage
      exit 1
    fi
    source $SIMPLETON_REPO/lib/dna-clone || exit 1
    begin_for subject in "${subjects[@]:1}"; doo
      dna_clone "${subjects[0]}" "$subject" || exit 1
    end_for
    ;;
  move|mv)
    if [[ ${#subjects[*]} -lt 2 ]]; then
      err "clone command must be followed by 2 parameters"
      show_usage
      exit 1
    fi
    source $SIMPLETON_REPO/lib/dna-move || exit 1
    local last=${#subjects[*]}
    let last--
    begin_for subject in "${subjects[@]:0:$last}"; doo
      dna_move "$subject" "${parameters[$last]}" || exit 1
    end_for
    ;;
  link)
    if [[ ${#subjects[*]} -lt 2 ]]; then
      err "clone command must be followed by 2 parameters"
      show_usage
      exit 1
    fi
    source $SIMPLETON_REPO/lib/dna-link || exit 1
    begin_for subject in "${subjects[@]:1}"; doo
      dna_link "${subjects[0]}" "$subject" || exit 1
    end_for
    ;;
  edit)
    source $SIMPLETON_REPO/lib/dna-edit || exit 1
    begin_for subject in "${parameters[@]}"; doo
      dna_edit "$(realpath $subject)" || exit 1
    end_for
    ;;
  new)
    source $SIMPLETON_REPO/lib/dna-new || exit 1
    begin_for subject in "${subjects[@]}"; doo
      dna_new "$subject" || exit 1
    end_for
    ;;
  add)
    source $SIMPLETON_REPO/lib/dna-add || exit 1
    begin_for subject in "${subjects[@]}"; doo
      dna_add "$subject" || exit 1
    end_for
    ;;
  help)
    show_usage
    exit 1
    ;;
  *)
    err "Unknown command: $command"
    show_usage
    exit 1
    ;;
esac

exit 0
