#!/bin/bash
set -u

source $SIMPLETON_REPO/lib/pre-bash "$0" "$@"
set "${real_params[@]}"; shift

optional_var trace           3             # 0 means no tracing output, higher numbers increases verbosity of tracing

source $SIMPLETON_REPO/lib/post-bash
source $SIMPLETON_REPO/lib/cell-common

command=${1:-help}; shift

parameters=( "$@" )

load_subjects() {
  subjects=()
  local subject 
  for subject in "${parameters[@]}"; do
    #subject=$(realpath "$subject")
    subjects+=( "$subject" )
  done

  if [[ ! "${subjects:-}" ]]; then
    subjects=( $PWD )
  fi
}

called_from=cli

show_usage() {
  warn "Usage: dna {command} [{parameters}]"
  warn "  commands:"
  warn "    copy {from} {to}..                              copies a cell from one location to a new one. Can use 'cp' instead."
  warn "    edit [{path to file(s) in cubes(s)}]            edit a file in an existing cell, updating and encrypting as needed"
  warn "    link {from} {to}..                              link a cell from one location to a new one. Can use 'ln' instead."
  warn "    move {from}.. {to}                              move a cell from one location to a new one. Can use 'mv' instead."
  warn "    new [{path to cubes(s)}]                        create new cells"
  warn "                                                    type={min|standard|...}"
  warn "    delete [{path to cube(s) or files in cubes}]    delete a file / folder / cube. Can use 'rm' instead."
}

load_subjects || exit 1
case $command in 
  copy|cp)
    if [[ ${#subjects[*]} -lt 2 ]]; then
      err "copy command must be followed by at least 2 parameters"
      show_usage
      exit 1
    fi
    source $SIMPLETON_REPO/lib/dna-copy || exit 1
    begin_for subject in "${subjects[@]:1}"; doo
      dna_copy "${subjects[0]}" "$subject" || exit 1
    end_for
    ;;
  move|mv)
    if [[ ${#subjects[*]} -lt 2 ]]; then
      err "move command must be followed by at least 2 parameters"
      show_usage
      exit 1
    fi
    source $SIMPLETON_REPO/lib/dna-move || exit 1
    last=${#subjects[*]}
    let last--
    begin_for subject in "${subjects[@]:0:$last}"; doo
      dna_move "$subject" "${parameters[$last]}" || exit 1
    end_for
    ;;
  link|ln)
    if [[ ${#subjects[*]} -lt 2 ]]; then
      err "link command must be followed by 2 parameters"
      show_usage
      exit 1
    fi
    source $SIMPLETON_REPO/lib/dna-link || exit 1
    begin_for subject in "${subjects[@]:1}"; doo
      dna_link "${subjects[0]}" "$subject" || exit 1
    end_for
    ;;
  edit)
    source $SIMPLETON_REPO/lib/dna-edit || exit 1
    begin_for subject in "${parameters[@]}"; doo
      dna_edit "$(realpath -m $subject)" || exit 1
    end_for
    ;;
  new)
    source $SIMPLETON_REPO/lib/dna-new || exit 1
    begin_for subject in "${subjects[@]}"; doo
      dna_new "$subject" || exit 1
    end_for
    ;;
# use edit or new instead
#  add)
#    source $SIMPLETON_REPO/lib/dna-add || exit 1
#    begin_for subject in "${subjects[@]}"; doo
#      dna_add "$subject" || exit 1
#    end_for
#    ;;
  delete|rm)
    source $SIMPLETON_REPO/lib/dna-delete || exit 1
    begin_for subject in "${subjects[@]}"; doo
      dna_delete "$subject" || exit 1
    end_for
    ;;
  help)
    show_usage
    exit 1
    ;;
  *)
    err "Unknown command: $command"
    show_usage
    exit 1
    ;;
esac

exit 0
